# ===================================================================
# Lemon Screenplay Dashboard — Environment Variables
# ===================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ===================================================================

# --- Firebase Storage ---
# Your Firebase Storage bucket name
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# Anthropic and Google AI keys belong in functions/.env. Never prefix a
# private credential with VITE_, because Vite embeds those values in the app.

# ===================================================================
# VPS Daemon Environment (set in systemd unit, NOT in this file)
# ===================================================================
# ANTHROPIC_API_KEY          — Anthropic key for V9 analysis engine
# FIREBASE_PROJECT_ID        — Firebase project ID
# FIREBASE_STORAGE_BUCKET    — Storage bucket (defaults to lemon-screenplay-dashboard.firebasestorage.app)
# GOOGLE_APPLICATION_CREDENTIALS — Path to service-account.json
# TMDB_API_KEY               — TMDB API key for produced-film detection
# DAILY_LLM_BUDGET_USD       — hard server-side Anthropic ceiling per UTC day (default: 100)

rules_version = '2';

// Lemon Screenplay Dashboard storage permissions.
// Partner share pages use persisted download URLs; direct bucket access is
// reserved for verified Lemon team accounts.
service firebase.storage {
  match /b/{bucket}/o {
    function isLemonIdentity() {
      return request.auth != null
          && request.auth.token.email is string
          && request.auth.token.email_verified == true
          && request.auth.token.email.matches('.*@lemonfilms[.]com$');
    }

    function isAdmin() {
      return isLemonIdentity()
          && request.auth.token.email == 'billy@lemonfilms.com';
    }

    function isTeamMember() {
      return isLemonIdentity();
    }

    match /Posters/{allPaths=**} {
      allow read: if isTeamMember();
      allow create, update: if isAdmin()
                            && request.resource.size < 10 * 1024 * 1024
                            && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }

    match /screenplays/{allPaths=**} {
      allow read: if isTeamMember();
      allow create, update: if isAdmin()
                            && request.resource.size < 50 * 1024 * 1024
                            && request.resource.contentType == 'application/pdf';
      allow delete: if isAdmin();
    }

    // Uploading here starts a paid analysis job, so readers cannot write.
    match /ingest-queue/{allPaths=**} {
      allow read: if isAdmin();
      allow create, update: if isAdmin()
                            && request.resource.size < 50 * 1024 * 1024
                            && request.resource.contentType == 'application/pdf';
      allow delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

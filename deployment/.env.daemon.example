# ═══════════════════════════════════════════════════════════════════════════════
# Lemon Ingest Daemon — Environment Variables
# Copy this to /opt/lemon-ingest/.env and fill in every value
# ═══════════════════════════════════════════════════════════════════════════════

# ── Firebase ──────────────────────────────────────────────────────────────────

# Project ID (never changes)
FIREBASE_PROJECT_ID=lemon-screenplay-dashboard

# Storage bucket. New Firebase projects use {project}.firebasestorage.app;
# legacy projects use {project}.appspot.com. Defaults to .firebasestorage.app
# if unset — check Firebase Console → Storage if you're unsure which yours is.
FIREBASE_STORAGE_BUCKET=lemon-screenplay-dashboard.firebasestorage.app

# Path to the service account JSON key you downloaded from:
#   Firebase Console → Project Settings → Service Accounts → Generate new private key
# Place the file at /opt/lemon-ingest/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=/opt/lemon-ingest/service-account.json

# ── Anthropic ─────────────────────────────────────────────────────────────────

# Direct Anthropic API key — daemon calls Anthropic directly (bypasses Cloud Fn)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: route through the Firebase Cloud Function proxy instead of direct
# Leave blank to call Anthropic directly (recommended for VPS — avoids double latency)
# LLM_PROXY_URL=https://llmproxy-p2xtj7baha-uc.a.run.app

# ── Optional: TMDB pre-screening ──────────────────────────────────────────────

# Checks if a screenplay title is already a produced film before spending API credits
# Get from: https://www.themoviedb.org/settings/api
# Leave blank to skip TMDB check
TMDB_API_KEY=

# ── Daemon tuning ─────────────────────────────────────────────────────────────

# Number of parallel workers (keep at 2 for Hostinger KVM 2 / shared plans)
# Increase to 3-4 only on dedicated CPU plans with plenty of RAM
DAEMON_CONCURRENCY=2

# Seconds between Firestore polls when queue is empty
DAEMON_POLL_INTERVAL=10

# Where to download PDFs during processing (auto-cleaned after each job)
DAEMON_WORK_DIR=/tmp/lemon

# Log directory (must be writable by the daemon user)
DAEMON_LOG_DIR=/var/log/lemon-daemon

# Daily Anthropic API call limit — shared with the Firebase Cloud Function
# Must match DAILY_BUDGET_LIMIT in budgetCounter.ts (default: 200)
DAILY_BUDGET_LIMIT=200

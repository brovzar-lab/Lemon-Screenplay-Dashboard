rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
// Lemon Screenplay Dashboard — Firestore Security Rules (Hardened)
//
// SECURITY MODEL (2026-06-06):
//   • All reads require anonymous auth (request.auth != null).
//   • Writes require auth + field validation + size caps.
//   • Destructive operations (delete, bulk update) are Admin-SDK-only where
//     possible. For collections where the browser needs soft-delete (update
//     with _deleted_at), we allow update but block hard delete.
//   • The VPS daemon and Cloud Functions use the Admin SDK, which bypasses
//     all security rules entirely — no client-side rules needed for them.
//
// AUTH TIMING NOTE (Firebase v10+):
//   The original rules had `allow read: if true` because of a timing bug
//   where signInAnonymously tokens didn't propagate on cold requests.
//   This is resolved in the client code: all Firestore call paths now
//   `await authReady` before issuing reads, and the SDK caches the
//   anonymous token via browserLocalPersistence. Safe to require auth.
//
// ADMIN SDK NOTE:
//   The Admin SDK (used by the VPS daemon and Cloud Functions) bypasses
//   all security rules. Rules below only govern browser/client access.
// ═══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────

    // True if the caller has an anonymous (or any) auth token.
    function isAuthenticated() {
      return request.auth != null;
    }

    // True if a string field exists, is a string, and respects the max length.
    function validString(data, field, maxLen) {
      return field in data
          && data[field] is string
          && data[field].size() <= maxLen;
    }

    // True if the request timestamp is a valid server timestamp or ISO string.
    // Used to ensure clients write reasonable timestamps.
    function hasTimestamp(data, field) {
      return field in data
          && (data[field] is string || data[field] is timestamp);
    }

    // ── uploaded_analyses ─────────────────────────────────────────────────
    // Screenplay analysis documents.
    //
    // SECURITY RATIONALE:
    //   • Read: auth required — prevents enumeration by unauthenticated bots.
    //     The data is non-PII but auth gates reduce scraping risk.
    //   • Create/Update: auth + field validation. The `source_file` field is
    //     required and capped at 500 chars to prevent payload abuse.
    //   • Delete: blocked for clients. Soft-delete via _deleted_at field is
    //     the supported pattern. Hard deletes only via Admin SDK (quarantine).
    match /uploaded_analyses/{docId} {
      // READ: authenticated users only.
      allow read: if isAuthenticated();

      // CREATE: authenticated + must include source_file.
      allow create: if isAuthenticated()
                    && 'source_file' in request.resource.data
                    && request.resource.data.source_file is string
                    && request.resource.data.source_file.size() <= 500;

      // UPDATE: authenticated + source_file must stay valid if present.
      // This covers soft-delete (_deleted_at), field patches, and restores.
      allow update: if isAuthenticated()
                    && (
                         !('source_file' in request.resource.data)
                         || (request.resource.data.source_file is string
                             && request.resource.data.source_file.size() <= 500)
                       );

      // DELETE: Admin SDK only. Clients use soft-delete or quarantine flags.
      allow delete: if false;
    }

    // ── screenplay_feedback ──────────────────────────────────────────────
    // User feedback and notes on individual screenplays.
    //
    // SECURITY RATIONALE:
    //   • Text field capped at 10 000 chars to prevent storage abuse.
    //   • screenplayId is required and capped to prevent orphaned feedback.
    //   • Delete allowed (users should be able to remove their own notes).
    match /screenplay_feedback/{docId} {
      allow read: if isAuthenticated();

      allow create, update: if isAuthenticated()
                   && 'screenplayId' in request.resource.data
                   && request.resource.data.screenplayId is string
                   && request.resource.data.screenplayId.size() <= 500
                   && (
                        !('text' in request.resource.data)
                        || (request.resource.data.text is string
                            && request.resource.data.text.size() <= 10000)
                      );

      allow delete: if isAuthenticated();
    }

    // ── producer_profiles ────────────────────────────────────────────────
    // Producer calibration profiles (per-user lens configuration).
    //
    // SECURITY RATIONALE:
    //   • Name capped at 200 chars. No unbounded blobs allowed.
    //   • Auth required for all operations to prevent profile enumeration.
    match /producer_profiles/{docId} {
      allow read: if isAuthenticated();

      allow create, update: if isAuthenticated()
                   && (
                        !('name' in request.resource.data)
                        || (request.resource.data.name is string
                            && request.resource.data.name.size() <= 200)
                      );

      allow delete: if isAuthenticated();
    }

    // ── shared_views ─────────────────────────────────────────────────────
    // Share tokens for partner access via capability URLs.
    //
    // SECURITY RATIONALE:
    //   • GET is intentionally public. Partners who receive a share URL are
    //     unauthenticated — the token IS the capability.
    //   • LIST requires dashboard authentication so public callers cannot
    //     enumerate live capability tokens.
    //   • CREATE: auth required (only dashboard users create share links).
    //   • UPDATE: auth required (prevents token hijacking via overwrites).
    //   • DELETE: auth required (revoke flow in shareService.ts).
    //   • EXPIRY: reads are denied server-side once expiresAt is in the past,
    //     so a leaked/forwarded link stops resolving even if the client check
    //     is bypassed. Legacy docs without expiresAt remain readable.
    //   • Doc size implicitly limited by the analysis snapshot structure.
    match /shared_views/{tokenId} {
      // Public single-document fetch — token is the capability — but not past expiry.
      // expiresAtMillis is epoch millis (a number) so it compares cleanly with
      // request.time.toMillis(). Legacy docs without it remain readable.
      allow get: if !('expiresAtMillis' in resource.data)
                 || resource.data.expiresAtMillis > request.time.toMillis();

      // Collection enumeration is restricted to dashboard users. Public partner
      // links resolve by token ID and never need list access.
      allow list: if isAuthenticated();

      // Only authenticated dashboard users may create, update, or revoke.
      allow create, update, delete: if isAuthenticated();
    }

    // ── brain_verdicts ───────────────────────────────────────────────────
    // Billy's personal verdicts for Obsidian Brain calibration.
    //
    // SECURITY RATIONALE:
    //   • billyVerdict is enum-validated to prevent injection of arbitrary values.
    //   • screenplayId is required and capped.
    //   • No delete from client — verdicts are permanent once set.
    match /brain_verdicts/{screenplayId} {
      allow read: if isAuthenticated();

      allow create, update: if isAuthenticated()
                   && 'screenplayId' in request.resource.data
                   && request.resource.data.screenplayId is string
                   && request.resource.data.screenplayId.size() <= 500
                   && 'billyVerdict' in request.resource.data
                   && request.resource.data.billyVerdict in
                      ['pass', 'consider', 'recommend', 'film_now'];

      // DELETE: Admin SDK only. Verdicts are permanent.
      allow delete: if false;
    }

    // ── _unrecognized_analyses (quarantine) ───────────────────────────────
    // Documents that failed type-guard validation.
    //
    // SECURITY RATIONALE:
    //   • Create: allowed (quarantine flow writes here before deleting source).
    //   • Read: allowed (settings panel shows quarantine count).
    //   • Update/Delete: Admin SDK only. Legacy quarantined docs shouldn't be
    //     modified or removed by the client — manual review required.
    match /_unrecognized_analyses/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false; // Admin SDK only — manual review
    }

    // ── ingest-queue ─────────────────────────────────────────────────────
    // Job documents written by the VPS daemon via Admin SDK.
    //
    // SECURITY RATIONALE:
    //   • READ: auth required. Dashboard progress widgets poll this collection
    //     but there's no reason for unauthenticated access.
    //   • WRITE: completely blocked for clients. Only the VPS daemon and
    //     Cloud Functions write here (Admin SDK bypasses all rules).
    match /ingest-queue/{jobId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin SDK only
    }

    // ── system ───────────────────────────────────────────────────────────
    // Internal system documents: daily API budget counters, watchdog state.
    //
    // SECURITY RATIONALE:
    //   • READ: auth required (budget data is operational, not public).
    //   • WRITE: blocked. Only Admin SDK (Cloud Functions + VPS daemon).
    match /system/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin SDK only
    }

    // ── Catch-all deny ───────────────────────────────────────────────────
    // Any collection not explicitly matched above is completely locked down.
    // This prevents accidental data exposure if new collections are added
    // without updating security rules.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
